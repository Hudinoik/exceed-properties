# ----------------------------------------------------------------
# Required environment variables for the Exceed Properties backend.
# Copy to .env and fill in real values. NEVER commit .env to git.
# ----------------------------------------------------------------

# Port the Node/Express server listens on. In production behind a reverse
# proxy (Render, Railway, etc.) this is whatever the platform assigns.
PORT=4000

# Where the database file lives. On Render/Railway, point this at a
# persistent disk mount (e.g. /var/data/app.sqlite). Locally a relative
# path is fine.
DATABASE_PATH=./server/data/app.sqlite

# Session signing secret. Long random string. Rotate to invalidate ALL
# sessions. Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=replace-me-with-48-random-bytes-base64

# Master key for encrypting integration secrets at rest. 32 bytes / 256 bits
# in base64. Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WARNING: losing this key means losing access to ALL stored API credentials.
# Back this up out-of-band (password manager, KMS, etc.).
ENCRYPTION_KEY=replace-me-with-32-random-bytes-base64

# Origin the SPA is served from (used for CORS allowlist + cookie SameSite).
# In dev: http://localhost:5173 — Vite default.
# In prod: your real https://your-domain.com (NO trailing slash).
CLIENT_ORIGIN=http://localhost:5173

# Set to 'production' on the live server to enable secure cookies + HSTS.
NODE_ENV=development

# Initial admin email + password used on the very first server start to
# create the bootstrap user. After that account exists, you can rotate /
# remove these — they're only read when the users table is empty.
SEED_ADMIN_EMAIL=w.marks@exceedproperties.co.za
SEED_ADMIN_PASSWORD=ChangeMeOnFirstLogin!
SEED_ADMIN_FIRST_NAME=Wayne
SEED_ADMIN_LAST_NAME=Marks
SEED_ADMIN_ROLE=director
